        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet emails = [],\n    subject = \"\",\n    message = \"\";\nfor (const item of $input.all()) {\n  emails.push(item.json.email);\n}\nconsole.log(emails.join(' '));\n\nswitch ($('extract the agent response').first().json.operation) {\n  case \"create\":\n    subject = \"New event has been schudeled\",\n    message = `Hello There 🖐️! \n  <br/>\n We inform you that you are invited into a new event with the team of ${$('extract the agent response').first().json.departement} <br/> ${$('extract the agent response').first().json.message}<br/> Best reguard`;\n    break;\n\n  case \"update\":\n    subject = \"updates about schudeled event\",\n    message = `Hello There ! <br/>\n\n We inform you that event with the team of ${$('extract the agent response').first().json.departement} will take a new place <br/> ${$('extract the agent response').first().json.message}<br/> Best reguard`;\n    break;\n    \n    case \"delete\":\n    subject = \"event has been canceled\",\n    message = `Hello There ! <br/>\n\n We inform you that event with the team of ${$('extract the agent response').first().json.departement} is set to be canceled <br/> ${$('extract the agent response').first().json.message}<br/> Best reguard`;\n    break;\n\n}\n\n\nreturn [\n  {\n      emails , subject, message\n  }\n];"
      },
