        "jsCode": "// 1. Grab the raw string from your AI node\nconst raw = $node[\"AI Agent\"].json.output;\n\n// 2. If it’s not a string, assume it’s already an object and return it\nif (typeof raw !== 'string') {\n  return raw;\n}\n\n// 3. Remove any ```…``` blocks (Python or JSON)\nlet cleaned = raw.replace(/\\s?```\\s*\\w*\\s*/g, '').trim();\n\n// 4. In case there’s an inline print(…) leftover, drop it too\ncleaned = cleaned.replace(/print\\([\\s\\S]*?\\)\\)/g, '').trim();\n\nconsole.log(cleaned)\n// 5. Parse the JSON\nconst obj = JSON.parse(cleaned);\n\n// 6. Return the object so subsequent nodes see it as JSON\nreturn obj;\n"
      },
